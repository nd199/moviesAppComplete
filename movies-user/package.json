{
  "name": "movies-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@mui/x-data-grid": "8.27.1",
    "@reduxjs/toolkit": "2.12.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "axios": "1.18.1",
    "date-fns": "4.4.0",
    "formik": "2.4.9",
    "js-cookie": "3.0.8",
    "lottie-react": "2.4.1",
    "react": "^18.2.0",
    "react-cookie": "8.1.2",
    "react-cookie-consent": "10.0.1",
    "react-dom": "^18.2.0",
    "react-icons": "5.6.0",
    "react-loader-spinner": "8.0.2",
    "react-lottie": "1.2.10",
    "react-password-meter": "1.0.0",
    "react-password-strength-bar": "0.4.1",
    "react-phone-number-input": "3.4.17",
    "react-redux": "9.3.0",
    "react-router-dom": "7.18.0",
    "react-scripts": "5.0.1",
    "react-toastify": "11.1.0",
    "recharts": "3.9.0",
    "slick-carousel": "1.8.1",
    "styled-components": "6.4.3",
    "swiper": "12.2.0",
    "timeago.js": "4.0.2",
    "typewriter-effect": "2.22.0",
    "uuid": "14.0.1",
    "web-vitals": "5.3.0",
    "yup": "1.7.1"
  },
  "scripts": {
    "start": "GENERATE_SOURCEMAP=false react-scripts start",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "analyze": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md}",
    "security-check": "npm audit",
    "pre-commit": "npm run lint && npm run test",
    "clean": "rm -rf build node_modules/.cache",
    "dev": "GENERATE_SOURCEMAP=false BROWSER=none npm start",
    "build:prod": "NODE_ENV=production GENERATE_SOURCEMAP=false npm run build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.8.5",
    "source-map-loader": "^5.0.0",
    "webpack-bundle-analyzer": "^5.3.0"
  }
}